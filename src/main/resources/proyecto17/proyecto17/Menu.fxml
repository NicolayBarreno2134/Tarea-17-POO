<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="proyecto17.proyecto17.MenuController"
            stylesheets="@styles.css">

    <left>
        <VBox styleClass="sidebar">
            <Label text="🛍️ MiTienda" styleClass="titulo"/>
            <Button text="Inicio"/>
            <Button text="Productos"/>
            <Button text="Categorías"/>
            <Button text="Clientes"/>
            <Button text="Ventas"/>
            <Button text="Reportes"/>
            <Button text="Usuarios"/>
            <Button text="Cerrar sesión" onAction="#cerrarSesion" styleClass="btn-danger"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER" style="-fx-padding: 20;">
            <Label text="Gestión de Productos" styleClass="titulo"/>

            <GridPane hgap="10" vgap="10">
                <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="codigoField" styleClass="text-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="nombreField" styleClass="text-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Categoría:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="categoriaBox" styleClass="combo-box" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Precio:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="precioField" styleClass="text-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Stock:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="stockField" styleClass="text-field" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Estado:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <ComboBox fx:id="estadoBox" styleClass="combo-box" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Nuevo" onAction="#nuevoProducto" styleClass="btn-primary"/>
                <Button text="Guardar" onAction="#guardarProducto" styleClass="btn-success"/>
                <Button text="Actualizar" onAction="#actualizarProducto" styleClass="btn-warning"/>
                <Button text="Eliminar" onAction="#eliminarProducto" styleClass="btn-danger"/>
                <Button text="Limpiar" onAction="#limpiarCampos" styleClass="btn-secondary"/>
            </HBox>

            <TableView fx:id="tablaProductos" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="120"/>
                    <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="100"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="80"/>
                    <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
