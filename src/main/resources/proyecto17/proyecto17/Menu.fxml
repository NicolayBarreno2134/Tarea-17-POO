<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f5f7fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto17.proyecto17.MenuController">

    <left>
        <VBox spacing="15" style="-fx-background-color: #00AB1E; -fx-padding: 20;">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="🛒 MiTienda" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Inicio" />
            <Button style="-fx-background-color: #1565c0; -fx-text-fill: white;" text="Productos" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Categorías" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Clientes" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Ventas" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Reportes" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Usuarios" />
            <Button onAction="#cerrarSesion" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Cerrar sesión" />
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding: 20; -fx-background-color: #A8FFB8;">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Gestión de Productos" />

            <GridPane hgap="10" vgap="10">
                <Label text="Código:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="codigoField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Categoría:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="categoriaBox" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="precioField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Stock:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="stockField" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="estadoBox" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#nuevoProducto" style="-fx-background-color: #1a73e8; -fx-text-fill: white;" text="Nuevo" />
                <Button onAction="#guardarProducto" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Guardar" />
                <Button onAction="#actualizarProducto" style="-fx-background-color: #f1c40f; -fx-text-fill: white;" text="Actualizar" />
                <Button onAction="#eliminarProducto" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Eliminar" />
                <Button onAction="#limpiarCampos" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" text="Limpiar" />
            </HBox>

            <TableView fx:id="tablaProductos" prefHeight="250" style="-fx-background-color: #E9FFB0;">
                <columns>
                    <TableColumn fx:id="colCodigo" prefWidth="80" text="Código" />
                    <TableColumn fx:id="colNombre" prefWidth="120" text="Nombre" />
                    <TableColumn fx:id="colCategoria" prefWidth="100" text="Categoría" />
                    <TableColumn fx:id="colPrecio" prefWidth="80" text="Precio" />
                    <TableColumn fx:id="colStock" prefWidth="80" text="Stock" />
                    <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
