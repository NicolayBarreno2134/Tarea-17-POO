<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyecto17.proyecto17.LoginController"
      alignment="CENTER" spacing="15"
      stylesheets="@styles.css">

   <Label text=" 🛒 MiTienda" styleClass="titulo"/>
   <Label text="Sistema de Ventas"/>

   <Label text="Usuario"/>
   <TextField fx:id="usuarioTextField" promptText="Ej: admin" styleClass="text-field"/>

   <Label text="Contraseña"/>
   <PasswordField fx:id="contraseñaTextField" promptText="Ingrese su contraseña" styleClass="password-field"/>

   <Label text="Rol"/>
   <ComboBox fx:id="rolComboBox" promptText="— Seleccionar —" styleClass="combo-box"/>

   <Button text="🚪  Ingresar" onAction="#ingresar" styleClass="btn-primary"/>
   <Label fx:id="lblError" style="-fx-text-fill: red; -fx-font-size: 12px;"/>
</VBox>

